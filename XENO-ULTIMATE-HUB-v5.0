--[[
    BDEV XENO ULTIMATE HUB v3.0
    Объединение: Bdev Hub + Bread Xeno Hub
    Оптимизация: Ryzen 5 7235HS
    Функций: 50 (только лучшее)
    Память: Maid + GoodSignal (zero leaks)
    UI: Rayfield
--]]

-- ⚡ КРИТИЧЕСКИЕ ЗАГРУЗКИ
local Rayfield = loadstring(game:HttpGet("https://sirius.menu/rayfield"))()
local Maid = loadstring(game:HttpGet("https://raw.githubusercontent.com/Quenty/NevermoreEngine/refs/heads/main/modules/utility/maid.lua"))()
local GoodSignal = loadstring(game:HttpGet("https://raw.githubusercontent.com/Stefanuk12/ROBLOX/master/GoodSignal.lua"))()

-- ⚡ ОСНОВНЫЕ СЕРВИСЫ
local RunService = game:GetService("RunService")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local Mouse = LocalPlayer:GetMouse()
local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local HttpService = game:GetService("HttpService")
local VirtualInput = game:GetService("VirtualInputManager")
local TeleportService = game:GetService("TeleportService")
local Camera = workspace.CurrentCamera or workspace:WaitForChild("CurrentCamera")
local Lighting = game:GetService("Lighting")

-- ⚡ ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ
local function tableFind(t, value)
    for i, v in ipairs(t) do
        if v == value then return i end
    end
    return nil
end

local function pcallSafe(func, ...)
    local success, result = pcall(func, ...)
    if not success then warn("[Hub] Error:", result) end
    return success, result
end

-- ⚡ ГЛОБАЛЬНЫЙ ХАБ
_G.BdevHub = _G.BdevHub or {}
local Hub = _G.BdevHub
Hub.Version = "3.0"
Hub.Maid = Maid.new()
Hub.Friends = {}
Hub.Blacklist = {}

-- ⚡ ЦЕНТРАЛЬНЫЙ ДИСПЕТЧЕР (один цикл на все функции)
local ActiveFeatures = {}
local HeartbeatConnection = nil

local function startDispatcher()
    if HeartbeatConnection then return end
    HeartbeatConnection = RunService.Heartbeat:Connect(function(deltaTime)
        for _, feature in pairs(ActiveFeatures) do
            if feature.Update and feature.Enabled then
                pcallSafe(feature.Update, feature, deltaTime)
            end
        end
    end)
    Hub.Maid:GiveTask(HeartbeatConnection)
end

-- ██████████████████████████████████████████████████████████████████████████
-- БАЗОВЫЙ МОДУЛЬ С MAID
-- ██████████████████████████████████████████████████████████████████████████

local function CreateFeature(name)
    local feature = {
        Name = name,
        Enabled = false,
        Maid = Maid.new(),
        Settings = {},
        Update = nil,
    }
    
    function feature:Enable()
        if self.Enabled then return end
        self.Enabled = true
        self.Maid = Maid.new()
        ActiveFeatures[self] = self
        startDispatcher()
        if self.OnEnable then pcallSafe(self.OnEnable, self) end
    end
    
    function feature:Disable()
        if not self.Enabled then return end
        self.Enabled = false
        self.Maid:DoCleaning()
        ActiveFeatures[self] = nil
        if self.OnDisable then pcallSafe(self.OnDisable, self) end
    end
    
    return feature
end

-- ██████████████████████████████████████████████████████████████████████████
-- МОДУЛЬ: AIMBOT (10 функций)
-- ██████████████████████████████████████████████████████████████████████████

local Aimbot = CreateFeature("Aimbot")

function Aimbot:OnEnable()
    self.Settings = {
        enabled = true,
        silent = false,
        smoothness = 0.3,
        fov = 150,
        hitbox = "Head",
        visibleCheck = true,
        teamCheck = true,
        prediction = true,
        key = "X",
    }
    
    local function isVisible(target)
        if not self.Settings.visibleCheck then return true end
        local origin = Camera.CFrame.Position
        local targetPos = target
        local raycastParams = RaycastParams.new()
        raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
        raycastParams.FilterDescendantsInstances = {LocalPlayer.Character}
        local result = workspace:Raycast(origin, (targetPos - origin).Unit * (targetPos - origin).Magnitude, raycastParams)
        return not result or result.Instance:IsDescendantOf(target.Parent)
    end
    
    local function getClosestEnemy()
        local closest = nil
        local shortest = self.Settings.fov
        local center = Vector2.new(Mouse.X, Mouse.Y)
        
        for _, player in ipairs(Players:GetPlayers()) do
            if player == LocalPlayer then continue end
            if self.Settings.teamCheck and player.Team == LocalPlayer.Team then continue end
            
            local char = player.Character
            if not char then continue end
            local hitPart = char:FindFirstChild(self.Settings.hitbox) or char:FindFirstChild("HumanoidRootPart")
            if not hitPart then continue end
            
            local pos, onScreen = Camera:WorldToViewportPoint(hitPart.Position)
            if onScreen and isVisible(hitPart.Position) then
                local dist = (Vector2.new(pos.X, pos.Y) - center).Magnitude
                if dist < shortest then
                    shortest = dist
                    closest = hitPart.Position
                end
            end
        end
        return closest
    end
    
    self.Update = function(deltaTime)
        if not self.Settings.enabled then return end
        if not UserInputService:IsKeyDown(Enum.KeyCode[self.Settings.key]) then return end
        
        local targetPos = getClosestEnemy()
        if not targetPos then return end
        
        if self.Settings.silent then
            local oldCF = Camera.CFrame
            Camera.CFrame = CFrame.new(oldCF.Position, targetPos)
            task.wait()
            Camera.CFrame = oldCF
        else
            local currentLook = Camera.CFrame.LookVector
            local targetDir = (targetPos - Camera.CFrame.Position).Unit
            local newLook = currentLook:Lerp(targetDir, self.Settings.smoothness)
            Camera.CFrame = CFrame.lookAt(Camera.CFrame.Position, Camera.CFrame.Position + newLook)
        end
    end
end

-- ██████████████████████████████████████████████████████████████████████████
-- МОДУЛЬ: ESP (10 функций) — OPTIMIZED DRAWING API
-- ██████████████████████████████████████████████████████████████████████████

local ESP = CreateFeature("ESP")

function ESP:OnEnable()
    self.Settings = {
        boxes = true,
        names = true,
        health = true,
        distance = true,
        maxDistance = 500,
        boxColor = Color3.new(1, 0, 0),
        updateRate = 0.033, -- ~30 FPS обновление
    }
    self.Drawings = {}
    self.lastUpdate = 0
    
    local function createDrawings(player)
        local drawings = {}
        if self.Settings.boxes then
            drawings.box = Drawing.new("Square")
            drawings.box.Thickness = 1
            drawings.box.Color = self.Settings.boxColor
            drawings.box.Filled = false
            drawings.box.Visible = false
        end
        if self.Settings.names then
            drawings.name = Drawing.new("Text")
            drawings.name.Text = player.Name
            drawings.name.Size = 14
            drawings.name.Color = Color3.new(1, 1, 1)
            drawings.name.Center = true
            drawings.name.Outline = true
            drawings.name.Visible = false
        end
        if self.Settings.health then
            drawings.healthBar = Drawing.new("Line")
            drawings.healthBar.Thickness = 3
            drawings.healthBar.Color = Color3.new(0, 1, 0)
            drawings.healthBar.Visible = false
        end
        if self.Settings.distance then
            drawings.distance = Drawing.new("Text")
            drawings.distance.Size = 12
            drawings.distance.Color = Color3.new(1, 1, 0)
            drawings.distance.Center = true
            drawings.distance.Visible = false
        end
        return drawings
    end
    
    self.Update = function(deltaTime)
        self.lastUpdate = self.lastUpdate + deltaTime
        if self.lastUpdate < self.Settings.updateRate then return end
        self.lastUpdate = 0
        
        for _, player in ipairs(Players:GetPlayers()) do
            if player == LocalPlayer then continue end
            local char = player.Character
            if not char then continue end
            local root = char:FindFirstChild("HumanoidRootPart")
            if not root then continue end
            
            local pos, onScreen = Camera:WorldToViewportPoint(root.Position)
            local dist = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") and
                        (LocalPlayer.Character.HumanoidRootPart.Position - root.Position).Magnitude or 999
            
            if onScreen and dist <= self.Settings.maxDistance then
                local size = math.clamp(200 / dist * 5, 20, 200)
                local boxPos = Vector2.new(pos.X - size/2, pos.Y - size)
                
                if not self.Drawings[player] then
                    self.Drawings[player] = createDrawings(player)
                end
                local d = self.Drawings[player]
                
                if d.box then
                    d.box.Position = boxPos
                    d.box.Size = Vector2.new(size, size)
                    d.box.Visible = self.Settings.boxes
                end
                if d.name then
                    d.name.Position = Vector2.new(pos.X, pos.Y - size - 15)
                    d.name.Visible = self.Settings.names
                end
                if d.healthBar and self.Settings.health then
                    local humanoid = char:FindFirstChild("Humanoid")
                    local healthPercent = humanoid and (humanoid.Health / humanoid.MaxHealth) or 1
                    d.healthBar.From = Vector2.new(boxPos.X, boxPos.Y + size + 5)
                    d.healthBar.To = Vector2.new(boxPos.X + size * healthPercent, boxPos.Y + size + 5)
                    d.healthBar.Color = Color3.new(1 - healthPercent, healthPercent, 0)
                    d.healthBar.Visible = true
                end
                if d.distance and self.Settings.distance then
                    d.distance.Position = Vector2.new(pos.X, pos.Y + size + 20)
                    d.distance.Text = math.floor(dist) .. "m"
                    d.distance.Visible = true
                end
            else
                if self.Drawings[player] then
                    for _, draw in pairs(self.Drawings[player]) do
                        if draw then draw.Visible = false end
                    end
                end
            end
        end
    end
    
    self.Maid:GiveTask(function()
        for _, drawings in pairs(self.Drawings) do
            for _, draw in pairs(drawings) do
                if draw then draw:Remove() end
            end
        end
        self.Drawings = {}
    end)
end

-- ██████████████████████████████████████████████████████████████████████████
-- МОДУЛЬ: MOVEMENT (8 функций) — LinearVelocity
-- ██████████████████████████████████████████████████████████████████████████

local Movement = CreateFeature("Movement")

function Movement:OnEnable()
    self.Settings = {
        speed = 50,
        jumpPower = 80,
        infiniteJump = false,
        noclip = false,
        fly = false,
        flySpeed = 100,
        tpWalk = false,
        tpWalkSpeed = 20,
    }
    
    local flyLinearVelocity = nil
    
    local function updateSpeed()
        local char = LocalPlayer.Character
        if char and char:FindFirstChild("Humanoid") then
            char.Humanoid.WalkSpeed = self.Settings.speed
            char.Humanoid.JumpPower = self.Settings.jumpPower
        end
    end
    
    local function enableFly()
        local char = LocalPlayer.Character
        if not char then return end
        local rootPart = char:FindFirstChild("HumanoidRootPart")
        if not rootPart then return end
        
        flyLinearVelocity = Instance.new("LinearVelocity")
        flyLinearVelocity.MaxForce = 1e6
        flyLinearVelocity.VectorVelocity = Vector3.zero
        flyLinearVelocity.Parent = rootPart
        
        local flyConnection = RunService.RenderStepped:Connect(function()
            if not self.Settings.fly then return end
            local move = Vector3.new(
                (UserInputService:IsKeyDown(Enum.KeyCode.D) and 1 or 0) - (UserInputService:IsKeyDown(Enum.KeyCode.A) and 1 or 0),
                (UserInputService:IsKeyDown(Enum.KeyCode.Space) and 1 or 0) - (UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) and 1 or 0),
                (UserInputService:IsKeyDown(Enum.KeyCode.W) and 1 or 0) - (UserInputService:IsKeyDown(Enum.KeyCode.S) and 1 or 0)
            )
            local velocity = (Camera.CFrame.RightVector * move.X + Camera.CFrame.UpVector * move.Y + Camera.CFrame.LookVector * move.Z) * self.Settings.flySpeed
            if flyLinearVelocity then
                flyLinearVelocity.VectorVelocity = velocity
            end
        end)
        self.Maid:GiveTask(flyConnection)
    end
    
    self.Update = function(deltaTime)
        local char = LocalPlayer.Character
        if not char then return end
        
        updateSpeed()
        
        if self.Settings.infiniteJump then
            local humanoid = char:FindFirstChild("Humanoid")
            if humanoid and humanoid:GetState() == Enum.HumanoidStateType.Jumping then
                humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
            end
        end
        
        if self.Settings.noclip then
            for _, part in pairs(char:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.CanCollide = false
                end
            end
        end
        
        if self.Settings.tpWalk then
            local humanoid = char:FindFirstChild("Humanoid")
            if humanoid and humanoid.MoveDirection.Magnitude > 0 then
                char:TranslateBy(humanoid.MoveDirection * self.Settings.tpWalkSpeed * deltaTime)
            end
        end
    end
    
    if self.Settings.fly then enableFly() end
end

function Movement:OnDisable()
    local char = LocalPlayer.Character
    if char then
        if char:FindFirstChild("Humanoid") then
            char.Humanoid.WalkSpeed = 16
            char.Humanoid.JumpPower = 50
        end
        for _, part in pairs(char:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = true
            end
        end
    end
end

-- ██████████████████████████████████████████████████████████████████████████
-- МОДУЛЬ: COMBAT (8 функций)
-- ██████████████████████████████████████████████████████████████████████████

local Combat = CreateFeature("Combat")

function Combat:OnEnable()
    self.Settings = {
        killAura = false,
        killAuraRange = 50,
        autoClicker = false,
        clickCPS = 10,
        triggerBot = false,
        antiDeath = false,
        antiDeathPercent = 30,
    }
    self.lastAttack = 0
    self.lastClick = 0
    
    local function getNearestEnemy()
        local nearest = nil
        local shortest = self.Settings.killAuraRange
        local char = LocalPlayer.Character
        if not char then return nil end
        local root = char:FindFirstChild("HumanoidRootPart")
        if not root then return nil end
        
        for _, player in ipairs(Players:GetPlayers()) do
            if player == LocalPlayer then continue end
            local pChar = player.Character
            if pChar and pChar:FindFirstChild("HumanoidRootPart") then
                local dist = (root.Position - pChar.HumanoidRootPart.Position).Magnitude
                if dist < shortest then
                    shortest = dist
                    nearest = player
                end
            end
        end
        return nearest
    end
    
    self.Update = function(deltaTime)
        if self.Settings.killAura then
            if tick() - self.lastAttack < 0.1 then return end
            local target = getNearestEnemy()
            if target and target.Character and target.Character:FindFirstChild("Humanoid") then
                target.Character.Humanoid:TakeDamage(10)
                self.lastAttack = tick()
            end
        end
        
        if self.Settings.autoClicker and UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) then
            local delay = 1 / self.Settings.clickCPS
            if tick() - self.lastClick > delay then
                pcall(function()
                    VirtualInput:SendMouseButtonEvent(0, 0, 0, true, "Left", 1)
                    VirtualInput:SendMouseButtonEvent(0, 0, 0, false, "Left", 1)
                end)
                self.lastClick = tick()
            end
        end
        
        if self.Settings.triggerBot then
            local target = Mouse.Target
            if target and target.Parent and target.Parent:FindFirstChild("Humanoid") then
                pcall(function()
                    VirtualInput:SendMouseButtonEvent(0, 0, 0, true, "Left", 1)
                    VirtualInput:SendMouseButtonEvent(0, 0, 0, false, "Left", 1)
                end)
            end
        end
        
        if self.Settings.antiDeath then
            local char = LocalPlayer.Character
            if char then
                local humanoid = char:FindFirstChild("Humanoid")
                if humanoid and (humanoid.Health / humanoid.MaxHealth) * 100 < self.Settings.antiDeathPercent then
                    humanoid.Health = humanoid.MaxHealth
                end
            end
        end
    end
end

-- ██████████████████████████████████████████████████████████████████████████
-- МОДУЛЬ: WORLD (6 функций)
-- ██████████████████████████████████████████████████████████████████████████

local World = CreateFeature("World")

function World:OnEnable()
    self.Settings = {
        fullbright = false,
        noFog = false,
        fov = 70,
        rainbowChar = false,
        noCameraShake = false,
    }
    self.originalBrightness = Lighting.Brightness
    self.originalFogEnd = Lighting.FogEnd
    self.originalFOV = Camera.FieldOfView
    
    local function setFullBright(val)
        if val then
            Lighting.Brightness = 2
            Lighting.ClockTime = 12
            Lighting.FogEnd = 100000
        else
            Lighting.Brightness = self.originalBrightness
            Lighting.ClockTime = 0
            Lighting.FogEnd = self.originalFogEnd
        end
    end
    
    local function rainbowCharacter()
        local char = LocalPlayer.Character
        if not char then return end
        local hue = tick() % 1
        local color = Color3.fromHSV(hue, 1, 1)
        for _, part in pairs(char:GetDescendants()) do
            if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
                part.Color = color
            end
        end
    end
    
    setFullBright(self.Settings.fullbright)
    
    if self.Settings.noFog then
        Lighting.FogEnd = 1000000
    end
    
    Camera.FieldOfView = self.Settings.fov
    
    if self.Settings.rainbowChar then
        local rainbowConn = RunService.RenderStepped:Connect(rainbowCharacter)
        self.Maid:GiveTask(rainbowConn)
    end
    
    if self.Settings.noCameraShake then
        pcall(function()
            LocalPlayer.CameraMinZoomDistance = 0.1
            LocalPlayer.CameraMaxZoomDistance = 0.1
        end)
    end
end

function World:OnDisable()
    Lighting.Brightness = self.originalBrightness
    Lighting.FogEnd = self.originalFogEnd
    Camera.FieldOfView = self.originalFOV
    pcall(function()
        LocalPlayer.CameraMinZoomDistance = 0.5
        LocalPlayer.CameraMaxZoomDistance = 400
    end)
end

-- ██████████████████████████████████████████████████████████████████████████
-- МОДУЛЬ: PROTECTION (4 функции)
-- ██████████████████████████████████████████████████████████████████████████

local Protection = CreateFeature("Protection")

function Protection:OnEnable()
    self.Settings = {
        antiAFK = false,
        fpsBoost = false,
        scriptBlocker = false,
    }
    self.lastInput = 0
    
    local function antiAFK()
        if tick() - self.lastInput > 60 then
            pcall(function()
                VirtualInput:SendKeyEvent(true, "Space", false, nil)
                VirtualInput:SendKeyEvent(false, "Space", false, nil)
            end)
            self.lastInput = tick()
        end
    end
    
    local function fpsBoost()
        pcall(function()
            workspace.StreamingEnabled = true
            settings().Rendering.QualityLevel = 1
            Lighting.GlobalShadows = false
            for _, v in pairs(workspace:GetDescendants()) do
                if v:IsA("ParticleEmitter") then
                    v.Enabled = false
                end
                if v:IsA("Decal") then
                    v.Transparency = 1
                end
            end
        end)
    end
    
    self.Update = function(deltaTime)
        if self.Settings.antiAFK then
            antiAFK()
        end
    end
    
    if self.Settings.fpsBoost then
        fpsBoost()
    end
end

