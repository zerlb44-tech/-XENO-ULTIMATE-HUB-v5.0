    Callback = function(v) ESP.Settings.distance = v end
})

VisualsTab:CreateSlider({
    Name = "Макс дистанция ESP",
    Range = {100, 1000},
    Increment = 50,
    CurrentValue = 500,
    Callback = function(v) ESP.Settings.maxDistance = v end
})

-- MOVEMENT TAB
MovementTab:CreateToggle({
    Name = "🏃 Speed Hack",
    CurrentValue = false,
    Callback = function(v) 
        Movement.Settings.speed = v and 50 or 16
        Movement:Enable()
        if not v then Movement:Disable() end
    end
})

MovementTab:CreateSlider({
    Name = "Скорость",
    Range = {16, 300},
    Increment = 1,
    CurrentValue = 50,
    Callback = function(v) Movement.Settings.speed = v end
})

MovementTab:CreateToggle({
    Name = "🦘 Infinite Jump",
    CurrentValue = false,
    Callback = function(v) Movement.Settings.infiniteJump = v; if v then Movement:Enable() else Movement:Disable() end end
})

MovementTab:CreateToggle({
    Name = "🧱 Noclip",
    CurrentValue = false,
    Callback = function(v) Movement.Settings.noclip = v; if v then Movement:Enable() else Movement:Disable() end end
})

