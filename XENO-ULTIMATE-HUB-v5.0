-- WORLD TAB
WorldTab:CreateToggle({
    Name = "☀️ Fullbright",
    CurrentValue = false,
    Callback = function(v) World.Settings.fullbright = v; if v then World:Enable() else World:Disable() end end
})

WorldTab:CreateToggle({
    Name = "🌫️ No Fog",
    CurrentValue = false,
    Callback = function(v) World.Settings.noFog = v; if v then World:Enable() else World:Disable() end end
})

WorldTab:CreateSlider({
    Name = "🎥 FOV Changer",
    Range = {30, 120},
    Increment = 1,
    CurrentValue = 70,
    Callback = function(v) World.Settings.fov = v; if World.Enabled then Camera.FieldOfView = v end end
})

WorldTab:CreateToggle({
    Name = "🌈 Rainbow Character",
    CurrentValue = false,
    Callback = function(v) World.Settings.rainbowChar = v; if v then World:Enable() else World:Disable() end end
})

-- PROTECTION TAB
ProtectionTab:CreateToggle({
    Name = "💤 Anti AFK",
    CurrentValue = false,
    Callback = function(v) Protection.Settings.antiAFK = v; if v then Protection:Enable() else Protection:Disable() end end
})

ProtectionTab:CreateToggle({
    Name = "🚀 FPS Boost",
    CurrentValue = false,
    Callback = function(v) Protection.Settings.fpsBoost = v; if v then Protection:Enable() else Protection:Disable() end end
})

ProtectionTab:CreateButton({
    Name = "🔄 Rejoin",
    Callback = function()
        pcall(function() TeleportService:Teleport(game.PlaceId, LocalPlayer) end)
    end
})

ProtectionTab:CreateButton({
    Name = "🎲 Server Hop",
    Callback = function()
        pcall(function()
            local data = HttpService:JSONDecode(game:HttpGet("https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?limit=100"))
            local servers = {}
            for _, v in pairs(data.data) do
                if v.playing < v.maxPlayers then
                    table.insert(servers, v.id)
                end
            end
            if #servers > 0 then
                TeleportService:TeleportToPlaceInstance(game.PlaceId, servers[math.random(1, #servers)], LocalPlayer)
            end
        end)
    end
})

-- Уведомление
Rayfield:Notify({
    Title = "🍞 BDEV XENO HUB",
    Content = "v" .. Hub.Version .. " загружен! by Bdev & Bread",
    Duration = 5,
})

-- Очистка при выгрузке
Hub.Maid:GiveTask(function()
    Aimbot:Disable()
    ESP:Disable()
    Movement:Disable()
    Combat:Disable()
    World:Disable()
    Protection:Disable()
end)

print("BDEV XENO ULTIMATE HUB v3.0 loaded!")

return Hub
